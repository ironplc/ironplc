# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# Fine-grained PAT with admin:webhooks on the repo and issues:write.
github_token = ""

# Example: "ironplc"
github_owner = "ironplc"

# Example: "ironplc" (repo name only, not "owner/repo").
github_repo = "ironplc"

# Public HTTPS endpoint where the orchestrator listens, e.g.
# https://your-reserved-name.ngrok-free.app/webhook for local dev.
webhook_url = ""

# Random high-entropy string; put the same value in
# agents/issue-resolver/.env as GITHUB_WEBHOOK_SECRET.
webhook_secret = ""
