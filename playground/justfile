# Build the IronPLC playground (wasm + static files)

# Install build tools
setup:
  cargo install wasm-pack

# Build the wasm package and assemble the deployable site into _build/
compile:
  mkdir -p _build/pkg
  npm install
  wasm-pack build ../compiler/playground --target web --out-dir ../../playground/_build/pkg --no-typescript
  cp node_modules/uplot/dist/uPlot.esm.js _build/
  cp node_modules/uplot/dist/uPlot.min.css _build/
  cp *.html *.js *.css *.txt *.xml _build/

# Run end-to-end tests (requires a compiled _build/)
test: compile
  npx playwright install chromium
  npx playwright test

# Build everything (CI entry point)
ci: setup test

# Serve locally for development
serve: compile
  cd _build && python3 -m http.server 8080

# Clean build artifacts
clean:
  rm -rf _build/
