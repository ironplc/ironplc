# Build the IronPLC web app (wasm + static files)

# Install build tools
setup:
  cargo install wasm-pack

# Build the wasm package and assemble the deployable site into _build/
compile:
  mkdir -p _build/pkg
  wasm-pack build ../compiler/web-app --target web --out-dir ../../web/_build/pkg --no-typescript
  cp index.html app.js style.css _build/

# Build everything (CI entry point)
ci: setup compile

# Serve locally for development
serve: compile
  cd _build && python3 -m http.server 8080

# Clean build artifacts
clean:
  rm -rf _build/
