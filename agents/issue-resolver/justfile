set dotenv-load := true

alias ci := default
default: setup test

setup:
    python3 -m venv .venv
    .venv/bin/pip install --upgrade pip
    .venv/bin/pip install -r requirements.txt pytest pytest-asyncio

test:
    .venv/bin/python -m pytest tests/ -v

serve port='8000':
    .venv/bin/uvicorn main:app --port {{port}} --reload

health port='8000':
    curl -s -i localhost:{{port}}/health

webhook ACTION='opened' LABEL='status/triage' NUMBER='1' EVENT='issues' port='8000':
    #!/usr/bin/env bash
    set -euo pipefail
    BODY=$(printf '{"action":"%s","issue":{"number":%s,"body":"smoke test"},"label":{"name":"%s"},"sender":{"login":"smoke"}}' '{{ACTION}}' '{{NUMBER}}' '{{LABEL}}')
    SIG="sha256=$(printf '%s' "$BODY" | openssl dgst -sha256 -hmac "$GITHUB_WEBHOOK_SECRET" -hex | awk '{print $2}')"
    curl -s -i -X POST localhost:{{port}}/webhook \
      -H "X-Hub-Signature-256: $SIG" \
      -H "X-GitHub-Event: {{EVENT}}" \
      -H "Content-Type: application/json" \
      --data "$BODY"

webhook-bogus port='8000':
    #!/usr/bin/env bash
    set -euo pipefail
    curl -s -i -X POST localhost:{{port}}/webhook \
      -H "X-Hub-Signature-256: sha256=bad" \
      -H "X-GitHub-Event: issues" \
      -H "Content-Type: application/json" \
      --data '{"action":"opened","issue":{"number":1}}'

ledger n='20':
    sqlite3 ledger.db "SELECT ts, event_type, stage, issue_number, details_json FROM events ORDER BY id DESC LIMIT {{n}};"
