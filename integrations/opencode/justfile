# OpenCode integration tests.
#
# Validates that IronPLC's MCP server (`ironplcmcp`) works with the OpenCode
# terminal agent. See README.md for prerequisites.

# Install the pinned OpenCode CLI.
setup:
  npm ci

# Deterministic: assert OpenCode loads the IronPLC MCP server and all its tools.
# Requires `ironplcmcp` (build with `cd ../../compiler && cargo build --release -p ironplc-mcp`).
smoke:
  node test/connectivity.mjs

# Deterministic hard gate: drive OpenCode against a fake model that always calls
# `check`, proving the tool-call wiring (catalog -> args -> MCP round-trip). No
# Ollama required.
mock-e2e:
  node test/mock-e2e.mjs

# Real-agent end-to-end against a local Ollama model (fidelity signal). Requires
# a running Ollama server with the model pulled (default: qwen2.5:1.5b).
agent-e2e:
  node test/agent.mjs

# Run all layers.
e2e: smoke mock-e2e agent-e2e
